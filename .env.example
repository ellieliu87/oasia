# NEXUS MBS — Environment Configuration Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your secrets.
# Lines starting with # are comments and are ignored.
# ─────────────────────────────────────────────────────────────────────────────


# ── OpenAI API ────────────────────────────────────────────────────────────────
# Required for the multi-agent Portfolio Planning workflow.
# Without this key the agent panel shows stub responses; all analytics still work.
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=


# ── Weights & Biases / Weave tracing ─────────────────────────────────────────
# Optional — enables Weave dashboard for agent call tracing and evaluation.
# Get your key at: https://wandb.ai/authorize
WANDB_API_KEY=
WANDB_ENTITY=your-wandb-username-or-team
WANDB_PROJECT=nexus-mbs


# ── Intex API ─────────────────────────────────────────────────────────────────
# Required only if you want live Intex prepay/analytics data.
INTEX_API_URL=https://api.intex.com/v1
INTEX_API_KEY=


# ── Authentication — LDAP / Active Directory ──────────────────────────────────
#
# PRODUCTION (corporate AD):
#   Set LDAP_SERVER to your company's AD server address.
#   Ask your IT team for the correct server hostname and bind DN format.
#
#   Common bind DN formats:
#     UPN format (most common):       {username}@yourcompany.com
#     Down-level logon name:          YOURDOMAIN\{username}
#     Full LDAP DN:                   uid={username},ou=users,dc=yourcompany,dc=com
#
#   Examples:
#     LDAP_SERVER=ldap://ad.yourcompany.com
#     LDAP_SERVER=ldaps://ad.yourcompany.com     (with SSL/TLS, also set LDAP_USE_SSL=true)
#     LDAP_USE_SSL=false
#     LDAP_USER_DN_TEMPLATE={username}@yourcompany.com
#
# DEVELOPMENT / LOCAL TESTING (no corporate laptop):
#   Set LDAP_SERVER=mock:// to enable the built-in mock auth.
#   In mock mode, any username is accepted with the password set in LDAP_MOCK_PASSWORD.
#   DO NOT use mock mode in production.
#
LDAP_SERVER=mock://
LDAP_USE_SSL=false
LDAP_USER_DN_TEMPLATE={username}@yourcompany.com

# Password accepted for all users in mock:// mode (dev/test only).
LDAP_MOCK_PASSWORD=oasis-test


# ── Data Paths ────────────────────────────────────────────────────────────────
# Defaults are relative to the repo root; override only if you need custom locations.
MARKET_DATA_DIR=./data/market_data/
SNAPSHOT_DB_PATH=./data/snapshots.db
CACHE_DIR=./data/cache/


# ── Model Parameters ──────────────────────────────────────────────────────────
N_RATE_PATHS=256

# Path to trained neural prepayment model.
# Generate with: uv run python scripts/generate_hypothetical_prepay_model.py
PREPAY_MODEL_PATH=./data/models/prepay_model.pkl

# Path to BGM0.5 term structure model.
# Generate with: uv run python scripts/generate_hypothetical_bgm_model.py
BGM_MODEL_PATH=./data/models/bgm_model.pkl
TERM_STRUCTURE_PATH=./data/market_data/


# ── Universe Configuration ────────────────────────────────────────────────────
UNIVERSE_PRODUCT_TYPES=CC30,CC15,GN30,GN15


# ── Risk Limits ───────────────────────────────────────────────────────────────
EVE_LIMIT_PCT=-5.0


# ── UI ────────────────────────────────────────────────────────────────────────
GRADIO_PORT=7860
